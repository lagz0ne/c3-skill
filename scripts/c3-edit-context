#!/usr/bin/env bash
#
# C3 Edit Context - PreToolUse Hook for Edit/Write
#
# Non-blocking hook that surfaces relevant patterns when editing files
# that are part of C3-documented components.
#
# Input: JSON with tool_input containing file_path
# Output: JSON with additionalContext (informative, not blocking)
#

set -uo pipefail

# Require jq for JSON parsing
command -v jq >/dev/null 2>&1 || exit 0

PROJECT_DIR="${CLAUDE_PROJECT_DIR:-$(pwd)}"
C3_DIR="$PROJECT_DIR/.c3"

# Exit silently if no C3 docs
[[ -d "$C3_DIR" ]] || exit 0

# Read tool input from stdin
INPUT=$(cat)

# Extract file path from input
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null)
[[ -z "$FILE_PATH" ]] && exit 0

# Normalize path (remove project dir prefix if present)
RELATIVE_PATH="${FILE_PATH#$PROJECT_DIR/}"

# Search for component that owns this file
find_component() {
    local target_file="$1"

    for comp_file in "$C3_DIR"/c3-*/c3-*.md; do
        [[ -f "$comp_file" ]] || continue

        # Check if this component's Code References mention our file
        if grep -q "$target_file" "$comp_file" 2>/dev/null; then
            echo "$comp_file"
            return 0
        fi
    done
    return 1
}

COMP_FILE=$(find_component "$RELATIVE_PATH")
[[ -z "$COMP_FILE" ]] && exit 0

# Found a matching component - extract context
COMP_ID=$(grep "^id:" "$COMP_FILE" 2>/dev/null | head -1 | sed 's/id: *//')
COMP_TITLE=$(grep "^title:" "$COMP_FILE" 2>/dev/null | head -1 | sed 's/title: *//')

# Get related refs
REFS=""
in_refs_section=false
while IFS= read -r line; do
    if [[ "$line" =~ ^##[[:space:]]*Related[[:space:]]*Refs ]]; then
        in_refs_section=true
        continue
    fi
    if [[ "$in_refs_section == true" && "$line" =~ ^## ]]; then
        break
    fi
    if [[ "$in_refs_section" == true && "$line" =~ ref-[a-z-]+ ]]; then
        ref_match=$(echo "$line" | grep -o 'ref-[a-z-]*' | head -1)
        if [[ -n "$ref_match" ]]; then
            # Get ref goal
            ref_file="$C3_DIR/refs/$ref_match.md"
            if [[ -f "$ref_file" ]]; then
                ref_goal=$(grep "^goal:" "$ref_file" 2>/dev/null | head -1 | sed 's/goal: *//')
                REFS="$REFS\n- **$ref_match**: $ref_goal"
            fi
        fi
    fi
done < "$COMP_FILE"

# Build context message
CONTEXT="<c3-edit-context>
**File:** \`$RELATIVE_PATH\`
**Component:** $COMP_ID ($COMP_TITLE)

**Applicable Patterns:**
$REFS

Ensure changes align with these refs. Read \`.c3/refs/{ref-id}.md\` for full details.
</c3-edit-context>"

# Output as JSON (non-blocking - just context)
CONTEXT_ESCAPED=$(echo -e "$CONTEXT" | jq -Rs .)

cat << 'ENDJSON'
{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
ENDJSON
echo "    \"additionalContext\": $CONTEXT_ESCAPED"
cat << 'ENDJSON'
  }
}
ENDJSON

exit 0
